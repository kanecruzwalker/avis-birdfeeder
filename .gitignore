# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment variables ─────────────────────────────────────────────────────
.env
# Keep .env.example committed — it documents required variables.

# ── Datasets (large — download separately via scripts/download_datasets.py) ───
data/
data/raw/
data/processed/
data/splits/
data/captures/

# Source modules under src/data/ are code -never ignore them
!src/data/
!src/data/*.py

# ── Model weights (large — tracked separately or downloaded) ──────────────────
models/**/*.pt
models/**/*.pth


# .pkl files are sklearn pipelines — small (~220KB each) and version-tracked
# for reproducibility. .pt/.pth (PyTorch checkpoints) and .hef (Hailo) stay
# ignored because those are large binaries regenerable from training scripts.


models/*.tflite
models/*.hef
*.onnx
# Keep model cards and label_map.json committed:
!models/label_map.json
!models/**/*.md
# Keep label map JSONs committed — small files needed for inference
!models/*.json

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── Testing and coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Ruff / linting cache ──────────────────────────────────────────────────────
.ruff_cache/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo


# pyenv local Python version pin — Pi-specific, not for dev machines
.python-version

# ── Config override backups (created by scripts/dev_config.py) ────────────────
configs/*.yaml.bak


# Labeling assistant outputs (dev-time)
data/labels/
data/smoke_test_images/

# Temporary smoke-test artefacts
inspect_smoke_test.py
smoke_test_ground_truth.json
test_frame.png
test_gemini_vision.py

# Frozen-extractor feature caches (large, regenerable from training scripts)
notebooks/results/**/track3_features_cache.npz
notebooks/results/**/*_features_cache.npz

# Phase 3 visual SVM baseline — 537MB, exceeds GitHub's 100MB limit.
# Regenerable from notebooks/visual_baseline.ipynb if needed for evaluation.
models/baselines/visual_svm_baseline.pkl