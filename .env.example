# .env.example
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# .env is in .gitignore.

# ── Environment ───────────────────────────────────────────────────────────────
# "development" | "production"
AVIS_ENV=development

# ── Xeno-canto API (Phase 2) ───────────────────────────────────────────────────────────────
# Register at https://xeno-canto.org and generate a key at xeno-canto.org/account/api
# Required to run scripts/download_datasets.py
XENO_CANTO_API_KEY =

# ── Audio device ──────────────────────────────────────────────────────────────
# Find your mic index by running:
# python -c "import sounddevice; print(sounddevice.query_devices())"
# Leave blank to use system default.
AUDIO_DEVICE_INDEX=

# ── Camera ────────────────────────────────────────────────────────────────────
PRIMARY_CAMERA_INDEX=0
SECONDARY_CAMERA_INDEX=1

# ── Push notifications (Phase 5) ─────────────────────────────────────────────
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# ── Email notifications (Phase 5) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=