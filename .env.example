# .env.example
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# .env is in .gitignore.

# ── Environment ───────────────────────────────────────────────────────────────
# "development" | "production"
AVIS_ENV=development

# ── Xeno-canto API (Phase 2) ──────────────────────────────────────────────────
# Register at https://xeno-canto.org and generate a key at xeno-canto.org/account/api
# Required to run scripts/download_datasets.py
XENO_CANTO_API_KEY=

# ── Audio device ──────────────────────────────────────────────────────────────
# Find your mic index by running:
# python -c "import sounddevice; print(sounddevice.query_devices())"
# Leave blank to use system default. Confirmed as 1 on deployed Pi.
AUDIO_DEVICE_INDEX=

# ── Camera ────────────────────────────────────────────────────────────────────
PRIMARY_CAMERA_INDEX=0
SECONDARY_CAMERA_INDEX=1

# ── Push notifications via Pushover (Phase 5) ─────────────────────────────────
# Sign up at https://pushover.net (free tier: 10,000 msgs/month).
# PUSHOVER_USER_KEY:  Your user key — found on the Pushover dashboard.
# PUSHOVER_APP_TOKEN: Create a new app at https://pushover.net/apps/build,
#                     name it "Avis Birdfeeder", copy the token here.
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# ── Webhook backend (Phase 6+) ────────────────────────────────────────────────
# Only needed when channels.webhook is true in configs/notify.yaml.
# Point at your backend observations endpoint when it exists.
WEBHOOK_AUTH_TOKEN=

# ── Email notifications (future) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=

# Google Gemini API key — get free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────
# Layer 2 — labeling-assistant review UI authentication
# ─────────────────────────────────────────────────────────────────
# Required for `python -m tools.labeler.ui`. Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be at least 16 characters. Anyone with this token + the URL can
# read pre-labels and write verifications, so don't commit it or share
# it publicly. The default bind is 127.0.0.1 (localhost only); use
# `--host 0.0.0.0` to expose over Tailscale/LAN, e.g. for phone access.
AVIS_WEB_TOKEN=
 